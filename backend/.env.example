# Server
PORT=5000
CLIENT_URL=http://localhost:3000
# URL pública del servidor backend (para construir URLs de archivos como avatares)
API_PUBLIC_URL=http://localhost:5000
NODE_ENV=development

# PostgreSQL
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_password
DB_NAME=citae
DB_PORT=5432

# JWT
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Google OAuth — generar en console.cloud.google.com
GOOGLE_CLIENT_ID=your_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=http://localhost:5000/api/auth/google/callback

# Groq LLM (opcional — mejora la narrativa de comparación)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
GROQ_MODEL_FAST=llama-3.1-8b-instant

# Rate limiting (requests por minuto por IP, valores por defecto si no se define)
RATE_LIMIT_EXTRACT=60
RATE_LIMIT_SEARCH=20
