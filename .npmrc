# CRA / react-scripts asume node_modules planos (hoisted).
# pnpm usa enlaces estrictos por defecto, lo que rompe webpack 5 de CRA.
node-linker=hoisted
shamefully-hoist=true

# No re-verificar el estado de dependencias antes de cada script (las nativas
# ya están construidas; evita el bloqueo por builds opcionales no usados).
verify-deps-before-run=false
